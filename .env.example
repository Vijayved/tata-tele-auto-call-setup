# ============================================
# WATI + Tata Tele Smartflo Bridge
# Copy this file to .env and fill in your values
# ============================================

# Server
PORT=3000
NODE_ENV=production

# Tata Tele Smartflo API
TATA_API_KEY=your_smartflo_api_key_here
TATA_API_URL=https://api-smartflo.tatateleservices.com/v1/click_to_call
CALLER_ID=your_did_number_here

# Agent Numbers (comma-separated for round-robin)
# Example: 919876543210,919876543211,919876543212
AGENT_NUMBERS=919876543210

# WATI Webhook Verification (optional - for security)
WATI_WEBHOOK_SECRET=your_secret_here

# Button Text to Match (the WhatsApp button text that triggers call)
TRIGGER_BUTTON_TEXT=Book Test

# Business Hours (IST)
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=19
BUSINESS_DAYS=1,2,3,4,5,6

# Debounce (seconds) - prevent duplicate calls from same number
DEBOUNCE_SECONDS=60

# Retry Config
MAX_RETRIES=2
RETRY_DELAY_MS=5000
